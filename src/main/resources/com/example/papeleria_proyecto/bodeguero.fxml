<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.papeleria_proyecto.controller.BodegueroController"
            prefWidth="1250"
            prefHeight="720"
            stylesheets="@estilos.css">

    <!-- ================= ENCABEZADO ================= -->

    <top>

        <VBox alignment="CENTER" spacing="10">

            <padding>
                <Insets top="15" bottom="15"/>
            </padding>

            <ImageView fitHeight="90"
                       fitWidth="90"
                       preserveRatio="true">

                <image>
                    <Image url="@logo.png"/>
                </image>

            </ImageView>

            <Label text="MÓDULO BODEGUERO"
                   styleClass="titulo"/>

            <Label text="Administración de Productos e Inventario"/>

        </VBox>

    </top>

    <!-- ================= MENÚ ================= -->

    <left>

        <VBox spacing="15"
              alignment="TOP_CENTER"
              prefWidth="220"
              styleClass="menu">

            <padding>
                <Insets top="20" left="15" right="15"/>
            </padding>

            <Button text="Productos"
                    prefWidth="180"
                    onAction="#mostrarProductos"/>

            <Button text="Categorías"
                    prefWidth="180"
                    onAction="#mostrarCategorias"/>

            <Button text="Detalle Ventas"
                    prefWidth="180"
                    onAction="#mostrarDetalleVentas"/>

            <Button text="Movimientos"
                    prefWidth="180"
                    onAction="#mostrarMovimientos"/>

        </VBox>

    </left>

    <!-- ================= PANEL CENTRAL ================= -->

    <center>

        <VBox spacing="20"
              styleClass="panel">

            <padding>
                <Insets top="15"
                        left="20"
                        right="20"
                        bottom="20"/>
            </padding>

            <!-- DATOS DEL PRODUCTO -->

            <GridPane hgap="12" vgap="12">

                <Label text="Código"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0"/>

                <TextField fx:id="txtCodigo"
                           promptText="Código"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0"/>

                <Label text="Nombre"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="0"/>

                <TextField fx:id="txtNombre"
                           promptText="Nombre"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="0"/>

                <Label text="Precio"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtPrecio"
                           promptText="Precio"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <Label text="Stock"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtStock"
                           promptText="Stock"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

                <Label text="Categoría"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="2"/>

                <ComboBox fx:id="cbCategoria"
                          prefWidth="200"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

                <Label text="Estado"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="2"/>

                <ComboBox fx:id="cbEstado"
                          prefWidth="200"
                          GridPane.columnIndex="3"
                          GridPane.rowIndex="2"/>

                <Label text="Descripción"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="3"/>

                <TextArea fx:id="txtDescripcion"
                          prefRowCount="3"
                          promptText="Descripción del producto"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"
                          GridPane.rowIndex="3"/>

            </GridPane>

            <!-- BOTONES CRUD -->

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="Nuevo"
                        onAction="#nuevo"/>

                <Button text="Guardar"
                        onAction="#guardar"/>

                <Button text="Editar"
                        onAction="#editar"/>

                <Button text="Eliminar"
                        onAction="#eliminar"/>

                <Button text="Limpiar"
                        onAction="#limpiar"/>

            </HBox>

            <!-- TABLA -->

            <TableView fx:id="tblDatos"
                       VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="col1"
                                 text="Código"
                                 prefWidth="120"/>

                    <TableColumn fx:id="col2"
                                 text="Nombre"
                                 prefWidth="220"/>

                    <TableColumn fx:id="col3"
                                 text="Descripción"
                                 prefWidth="240"/>

                    <TableColumn fx:id="col4"
                                 text="Precio"
                                 prefWidth="110"/>

                    <TableColumn fx:id="col5"
                                 text="Stock"
                                 prefWidth="90"/>

                    <TableColumn fx:id="col6"
                                 text="Estado"
                                 prefWidth="120"/>

                    <TableColumn fx:id="col7"
                                 text="Categoría"
                                 prefWidth="180"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>