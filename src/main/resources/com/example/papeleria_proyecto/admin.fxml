<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.papeleria_proyecto.controller.AdminController"
            prefHeight="650.0" prefWidth="1000.0"
            styleClass="border-pane" stylesheets="@estilos.css">

    <left>
        <VBox spacing="10" style="-fx-background-color:#2c3e50;" prefWidth="180">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>

            <Label text="PANEL ADMIN" style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;"/>

            <Button fx:id="btnUsuarios" text="Usuarios" maxWidth="Infinity" onAction="#mostrarUsuarios"/>
            <Button fx:id="btnProductos" text="Productos" maxWidth="Infinity" onAction="#mostrarProductos"/>
            <Button fx:id="btnCategorias" text="Categorías" maxWidth="Infinity" onAction="#mostrarCategorias"/>
            <Button fx:id="btnVentas" text="Ventas" maxWidth="Infinity" onAction="#mostrarVentas"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorTablas">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>


            <VBox fx:id="panelUsuarios" spacing="10" visible="true">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Gestión de Usuarios" style="-fx-font-size:18; -fx-font-weight:bold;"/>
                    <Button text="Mostrar" onAction="#mostrarTablaUsuarios"/>
                    <Button text="Nuevo" onAction="#nuevoUsuario"/>
                    <Button text="Editar" onAction="#editarUsuario"/>
                    <Button text="Eliminar" onAction="#eliminarUsuario"/>
                    <Label fx:id="lblEstadoUsuarios" text="Esperando datos..." style="-fx-font-weight:bold;"/>
                    <TextField fx:id="txtBuscarUsuarios" promptText="Buscar por nombre, usuario o correo" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarUsuarios"/>
                </HBox>
                <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdUsuario" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colNombreUsuario" text="Nombre" prefWidth="110"/>
                        <TableColumn fx:id="colApellidoUsuario" text="Apellido" prefWidth="110"/>
                        <TableColumn fx:id="colUsuario" text="Usuario" prefWidth="100"/>
                        <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="100"/>
                        <TableColumn fx:id="colCorreo" text="Correo" prefWidth="150"/>
                        <TableColumn fx:id="colEstadoUsuario" text="Estado" prefWidth="70"/>
                        <TableColumn fx:id="colIdRol" text="Rol" prefWidth="60"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="panelProductos" spacing="10" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Gestión de Productos" style="-fx-font-size:18; -fx-font-weight:bold;"/>
                    <Button text="Mostrar" onAction="#mostrarTablaProductos"/>
                    <Button text="Nuevo" onAction="#nuevoProducto"/>
                    <Button text="Editar" onAction="#editarProducto"/>
                    <Button text="Eliminar" onAction="#eliminarProducto"/>
                    <Label fx:id="lblEstadoProductos" text="Esperando datos..." style="-fx-font-weight:bold;"/>
                    <TextField fx:id="txtBuscarProductos" promptText="Buscar por código o nombre" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarProductos"/>
                </HBox>
                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdProducto" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                        <TableColumn fx:id="colNombreProducto" text="Nombre" prefWidth="130"/>
                        <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="150"/>
                        <TableColumn fx:id="colPrecio" text="Precio" prefWidth="80"/>
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
                        <TableColumn fx:id="colEstadoProducto" text="Estado" prefWidth="70"/>
                        <TableColumn fx:id="colIdCategoria" text="Categoría" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="panelCategorias" spacing="10" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Gestión de Categorías" style="-fx-font-size:18; -fx-font-weight:bold;"/>
                    <Button text="Mostrar" onAction="#mostrarTablaCategorias"/>
                    <Button text="Nueva" onAction="#nuevaCategoria"/>
                    <Button text="Editar" onAction="#editarCategoria"/>
                    <Button text="Eliminar" onAction="#eliminarCategoria"/>
                    <Label fx:id="lblEstadoCategorias" text="Esperando datos..." style="-fx-font-weight:bold;"/>
                    <TextField fx:id="txtBuscarCategorias" promptText="Buscar por nombre o descripción" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarCategorias"/>
                </HBox>
                <TableView fx:id="tablaCategorias" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdCategoriaTab" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colNombreCategoria" text="Nombre" prefWidth="200"/>
                        <TableColumn fx:id="colDescripcionCategoria" text="Descripción" prefWidth="300"/>
                    </columns>
                </TableView>
            </VBox>
            
            <VBox fx:id="panelVentas" spacing="10" visible="false">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Historial de Ventas" style="-fx-font-size:18; -fx-font-weight:bold;"/>
                    <Button text="Mostrar" onAction="#mostrarTablaVentas"/>
                    <Button text="Ver detalle" onAction="#verDetalleVenta"/>
                    <Label fx:id="lblEstadoVentas" text="Esperando datos..." style="-fx-font-weight:bold;"/>
                    <TextField fx:id="txtBuscarVentas" promptText="Buscar por ID o total" HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar" onAction="#buscarVentas"/>
                </HBox>
                <TableView fx:id="tablaVentas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdVenta" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colFecha" text="Fecha" prefWidth="150"/>
                        <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="90"/>
                        <TableColumn fx:id="colIva" text="IVA" prefWidth="80"/>
                        <TableColumn fx:id="colTotal" text="Total" prefWidth="90"/>
                        <TableColumn fx:id="colIdUsuarioVenta" text="Usuario" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>