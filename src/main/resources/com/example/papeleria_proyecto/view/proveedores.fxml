<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.papeleria_proyecto.controller.ProveedoresController">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Gestión de Proveedores" style="-fx-font-size:18; -fx-font-weight:bold;"/>
        <Button text="Mostrar Todos" onAction="#cargarProveedores"/>
        <Button text="Nuevo" onAction="#nuevoProveedor"/>
        <Button text="Editar" onAction="#editarProveedor"/>
        <Button text="Eliminar" onAction="#eliminarProveedor"/>
        <TextField fx:id="txtBuscar" promptText="Buscar proveedor..." HBox.hgrow="ALWAYS"/>
        <Button text="Buscar" onAction="#buscarProveedor"/>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <TableView fx:id="tablaProveedores" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colNombre" text="Nombre Empresa/Proveedor" prefWidth="150"/>
                <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="110"/>
                <TableColumn fx:id="colCorreo" text="Correo Electrónico" prefWidth="160"/>
                <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="200"/>
            </columns>
        </TableView>

        <VBox fx:id="panelFormulario" prefWidth="300" spacing="10" visible="false" managed="false">
            <Label fx:id="lblTituloFormulario" text="Nuevo Proveedor" style="-fx-font-size:16; -fx-font-weight:bold;"/>
            <TextField fx:id="txtNombre" promptText="Nombre"/>
            <TextField fx:id="txtTelefono" promptText="Teléfono (Ej: 0987654321)"/>
            <TextField fx:id="txtCorreo" promptText="Correo Electrónico"/>
            <TextField fx:id="txtDireccion" promptText="Dirección"/>
            <HBox spacing="10">
                <Button text="Guardar" onAction="#guardarProveedor"/>
                <Button text="Cancelar" onAction="#cancelarFormulario"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>