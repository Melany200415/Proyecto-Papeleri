<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1158.0" styleClass="border-pane" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.papeleria_proyecto.controller.AdminController">

    <left>
        <VBox prefWidth="180" spacing="10" style="-fx-background-color:#2c3e50;">
            <padding><Insets bottom="20" left="10" right="10" top="20" /></padding>

            <Label style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;" text="PANEL ADMIN" />

            <Button fx:id="btnUsuarios" maxWidth="Infinity" onAction="#mostrarUsuarios" text="Usuarios" />
            <Button fx:id="btnProductos" maxWidth="Infinity" onAction="#mostrarProductos" text="Productos" />
            <Button fx:id="btnCategorias" maxWidth="Infinity" onAction="#mostrarCategorias" text="Categorías" />
            <Button fx:id="btnVentas" maxWidth="Infinity" onAction="#mostrarVentas" text="Ventas" />

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorTablas">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>


            <VBox fx:id="panelUsuarios" spacing="10" visible="true">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Gestión de Usuarios" />
                    <Button onAction="#mostrarTablaUsuarios" text="Mostrar" />
                    <Button onAction="#nuevoUsuario" text="Nuevo" />
                    <Button onAction="#editarUsuario" text="Editar" />
                    <Button onAction="#eliminarUsuario" text="Eliminar" />
                    <Label fx:id="lblEstadoUsuarios" style="-fx-font-weight:bold;" text="Esperando datos..." />
                    <TextField fx:id="txtBuscarUsuarios" promptText="Buscar por nombre, usuario o correo" HBox.hgrow="ALWAYS" />
                    <Button onAction="#buscarUsuarios" text="Buscar" />
                </HBox>
                <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdUsuario" prefWidth="50" text="ID" />
                        <TableColumn fx:id="colNombreUsuario" prefWidth="145.0" text="Nombre" />
                        <TableColumn fx:id="colApellidoUsuario" prefWidth="113.0" text="Apellido" />
                        <TableColumn fx:id="colUsuario" prefWidth="102.0" text="Usuario" />
                        <TableColumn fx:id="colTelefono" prefWidth="99.0" text="Teléfono" />
                        <TableColumn fx:id="colCorreo" prefWidth="134.0" text="Correo" />
                        <TableColumn fx:id="colEstadoUsuario" prefWidth="91.0" text="Estado" />
                        <TableColumn fx:id="colIdRol" prefWidth="128.0" text="Rol" />
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="panelProductos" spacing="10" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Gestión de Productos" />
                    <Button onAction="#mostrarTablaProductos" text="Mostrar" />
                    <Button onAction="#nuevoProducto" text="Nuevo" />
                    <Button onAction="#editarProducto" text="Editar" />
                    <Button onAction="#eliminarProducto" text="Eliminar" />
                    <Label fx:id="lblEstadoProductos" style="-fx-font-weight:bold;" text="Esperando datos..." />
                    <TextField fx:id="txtBuscarProductos" promptText="Buscar por código o nombre" HBox.hgrow="ALWAYS" />
                    <Button onAction="#buscarProductos" text="Buscar" />
                </HBox>
                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdProducto" prefWidth="50" text="ID" />
                        <TableColumn fx:id="colCodigo" prefWidth="90" text="Código" />
                        <TableColumn fx:id="colNombreProducto" prefWidth="130" text="Nombre" />
                        <TableColumn fx:id="colDescripcion" prefWidth="150" text="Descripción" />
                        <TableColumn fx:id="colPrecio" prefWidth="80" text="Precio" />
                        <TableColumn fx:id="colStock" prefWidth="70" text="Stock" />
                        <TableColumn fx:id="colEstadoProducto" prefWidth="70" text="Estado" />
                        <TableColumn fx:id="colIdCategoria" prefWidth="90" text="Categoría" />
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="panelCategorias" spacing="10" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Gestión de Categorías" />
                    <Button onAction="#mostrarTablaCategorias" text="Mostrar" />
                    <Button onAction="#nuevaCategoria" text="Nueva" />
                    <Button onAction="#editarCategoria" text="Editar" />
                    <Button onAction="#eliminarCategoria" text="Eliminar" />
                    <Label fx:id="lblEstadoCategorias" style="-fx-font-weight:bold;" text="Esperando datos..." />
                    <TextField fx:id="txtBuscarCategorias" promptText="Buscar por nombre o descripción" HBox.hgrow="ALWAYS" />
                    <Button onAction="#buscarCategorias" text="Buscar" />
                </HBox>
                <TableView fx:id="tablaCategorias" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdCategoriaTab" prefWidth="60" text="ID" />
                        <TableColumn fx:id="colNombreCategoria" prefWidth="200" text="Nombre" />
                        <TableColumn fx:id="colDescripcionCategoria" prefWidth="300" text="Descripción" />
                    </columns>
                </TableView>
            </VBox>
            
            <VBox fx:id="panelVentas" spacing="10" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Historial de Ventas" />
                    <Button onAction="#mostrarTablaVentas" text="Mostrar" />
                    <Button onAction="#verDetalleVenta" text="Ver detalle" />
                    <Label fx:id="lblEstadoVentas" style="-fx-font-weight:bold;" text="Esperando datos..." />
                    <TextField fx:id="txtBuscarVentas" promptText="Buscar por ID o total" HBox.hgrow="ALWAYS" />
                    <Button onAction="#buscarVentas" text="Buscar" />
                </HBox>
                <TableView fx:id="tablaVentas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdVenta" prefWidth="50" text="ID" />
                        <TableColumn fx:id="colFecha" prefWidth="150" text="Fecha" />
                        <TableColumn fx:id="colSubtotal" prefWidth="90" text="Subtotal" />
                        <TableColumn fx:id="colIva" prefWidth="80" text="IVA" />
                        <TableColumn fx:id="colTotal" prefWidth="90" text="Total" />
                        <TableColumn fx:id="colIdUsuarioVenta" prefWidth="90" text="Usuario" />
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
