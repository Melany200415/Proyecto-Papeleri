<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="850.0"
            prefWidth="1250"
            stylesheets="@../css/estilos.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.papeleria_proyecto.controller.CajeroController">

    <top>
        <VBox alignment="CENTER"
              prefHeight="159.0"
              prefWidth="1250.0"
              spacing="8">

            <padding>
                <Insets bottom="15" top="15"/>
            </padding>

            <ImageView fitHeight="155.0"
                       fitWidth="140.0"
                       preserveRatio="true">
                <image>
                    <Image url="@../images/cajero.png"/>
                </image>
            </ImageView>

            <Label styleClass="cajero-title"
                   text="MÓDULO CAJERO"/>

            <Label styleClass="cajero-subtitle"
                   text="Registro y Gestión de Ventas"/>
        </VBox>
    </top>

    <center>
        <VBox prefWidth="1250.0"
              spacing="15"
              styleClass="cajero-panel">

            <padding>
                <Insets bottom="15"
                        left="20"
                        right="20"
                        top="15"/>
            </padding>

            <Button mnemonicParsing="false"
                    onAction="#cerrarSesion"
                    styleClass="btn-eliminar"
                    text="Cerrar Sesión"/>

            <GridPane hgap="12" vgap="12">

                <columnConstraints>
                    <ColumnConstraints prefWidth="100"/>
                    <ColumnConstraints prefWidth="250"/>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints prefWidth="100"/>
                    <ColumnConstraints prefWidth="200"/>
                    <ColumnConstraints prefWidth="100"/>
                </columnConstraints>

                <Label text="Buscar Por:"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0"/>

                <TextField fx:id="txtBuscarProducto"
                           onAction="#buscarProducto"
                           promptText="Ingrese nombre o código..."
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0"/>

                <Button onAction="#buscarProducto"
                        text="Buscar"
                        GridPane.columnIndex="2"
                        GridPane.rowIndex="0"/>

                <Label text="Producto:"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtProducto"
                           editable="false"
                           promptText="Nombre del producto"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <Label text="Stock Disponible:"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtStock"
                           editable="false"
                           promptText="0"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

                <Label text="Precio ($):"
                       GridPane.columnIndex="4"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtPrecio"
                           editable="false"
                           promptText="0.00"
                           GridPane.columnIndex="5"
                           GridPane.rowIndex="1"/>

                <Label text="Cantidad:"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="2"/>

                <Spinner fx:id="spCantidad"
                         GridPane.columnIndex="1"
                         GridPane.rowIndex="2"/>

                <Button onAction="#agregarProducto"
                        styleClass="btn-guardar"
                        text="+ Agregar al Carrito"
                        GridPane.columnIndex="2"
                        GridPane.columnSpan="2"
                        GridPane.rowIndex="2"/>

                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                </rowConstraints>
            </GridPane>

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#nuevaVenta"
                        styleClass="btn-nuevo"
                        text="Nueva Venta"/>

                <Button onAction="#eliminarProducto"
                        styleClass="btn-eliminar"
                        text="Eliminar Item Seleccionado"/>

                <Button onAction="#cobrar"
                        styleClass="btn-cobrar"
                        text="💳 Cobrar e Imprimir Comprobante"/>
            </HBox>

            <Label styleClass="titulo-tabla"
                   text="Carrito de Venta Actual"/>

            <TableView fx:id="tblCarrito"
                       prefHeight="280"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colCodigo"
                                 prefWidth="120"
                                 text="Código"/>

                    <TableColumn fx:id="colProducto"
                                 prefWidth="280"
                                 text="Producto"/>

                    <TableColumn fx:id="colCantidad"
                                 prefWidth="100"
                                 text="Cantidad"/>

                    <TableColumn fx:id="colPrecio"
                                 prefWidth="130"
                                 text="Precio Unitario"/>

                    <TableColumn fx:id="colSubtotal"
                                 prefWidth="150"
                                 text="Subtotal"/>
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Label styleClass="label-total-titulo"
                       text="TOTAL A PAGAR:"/>

                <Label fx:id="lblTotal"
                       styleClass="label-total-valor"
                       text="0.00"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>