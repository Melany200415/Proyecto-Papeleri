<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1250"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.papeleria_proyecto.controller.CajeroController"
            stylesheets="@../css/estilos.css">

    <!-- CABECERA -->
    <top>

        <VBox alignment="CENTER" spacing="8">

            <padding>
                <Insets top="15" bottom="15"/>
            </padding>

            <ImageView fitHeight="95"
                       fitWidth="95"
                       preserveRatio="true">

                <image>
                    <Image url="@../images/cajero.png"/>
                </image>

            </ImageView>

            <Label text="MÓDULO CAJERO"
                   styleClass="cajero-title"/>

            <Label text="Registro y Gestión de Ventas"
                   styleClass="cajero-subtitle"/>

        </VBox>

    </top>

    <center>

        <VBox spacing="20"
              styleClass="cajero-panel">

            <padding>
                <Insets top="20"
                        left="20"
                        right="20"
                        bottom="20"/>
            </padding>

            <!-- DATOS -->

            <GridPane hgap="15"
                      vgap="15">

                <columnConstraints>

                    <ColumnConstraints prefWidth="90"/>
                    <ColumnConstraints prefWidth="220"/>
                    <ColumnConstraints prefWidth="90"/>
                    <ColumnConstraints prefWidth="220"/>

                </columnConstraints>

                <Label text="Código"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtCodigo"
                           promptText="Código del producto"
                           GridPane.columnIndex="1"/>

                <Label text="Producto"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtProducto"
                           promptText="Nombre"
                           editable="false"
                           GridPane.columnIndex="3"/>

                <Label text="Cantidad"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1"/>

                <Spinner fx:id="spCantidad"
                         GridPane.columnIndex="1"
                         GridPane.rowIndex="1"/>

                <Label text="Precio"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtPrecio"
                           editable="false"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

            </GridPane>

            <!-- BOTONES -->

            <HBox alignment="CENTER"
                  spacing="15">

                <Button text="Agregar"
                        styleClass="btn-guardar"/>

                <Button text="Nueva Venta"
                        styleClass="btn-nuevo"/>

                <Button text="Eliminar"
                        styleClass="btn-eliminar"/>

                <Button text="Cobrar"
                        styleClass="btn-cobrar"/>

            </HBox>

            <!-- TABLA CARRITO -->

            <Label text="Carrito de Venta"
                   styleClass="titulo-tabla"/>
            <TableView fx:id="tblCarrito" VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="colCodigo"
                                 text="Código"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colProducto"
                                 text="Producto"
                                 prefWidth="260"/>

                    <TableColumn fx:id="colCantidad"
                                 text="Cantidad"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colPrecio"
                                 text="Precio"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colSubtotal"
                                 text="Subtotal"
                                 prefWidth="150"/>

                </columns>

            </TableView>

            <!-- TOTAL -->

            <HBox alignment="CENTER_RIGHT"
                  spacing="15">

                <Label text="TOTAL"
                       style="-fx-font-size:22;-fx-font-weight:bold;"/>

                <Label fx:id="lblTotal"
                       text="0.00"
                       style="-fx-font-size:24px; -fx-font-weight:bold; -fx-text-fill:#16A34A;"/>
            </HBox>

            <!-- HISTORIAL -->

            <Label text="Historial de Ventas"
                   styleClass="titulo-tabla"/>
            <TableView fx:id="tblVentas"
                       prefHeight="180">

                <columns>

                    <TableColumn fx:id="colVenta"
                                 text="Venta"
                                 prefWidth="90"/>

                    <TableColumn fx:id="colFecha"
                                 text="Fecha"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colCliente"
                                 text="Cliente"
                                 prefWidth="250"/>

                    <TableColumn fx:id="colTotalVenta"
                                 text="Total"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colEstado"
                                 text="Estado"
                                 prefWidth="140"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>