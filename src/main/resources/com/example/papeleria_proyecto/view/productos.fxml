<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.papeleria_proyecto.controller.ProductosController">

    <!-- BARRA SUPERIOR DE ACCIONES -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Gestión de Productos" style="-fx-font-size:18; -fx-font-weight:bold;"/>
        <Button text="Mostrar Todos" onAction="#cargarProductos"/>
        <Button text="Nuevo" onAction="#nuevoProducto"/>
        <Button text="Editar" onAction="#editarProducto"/>
        <Button text="Desactivar/Eliminar" onAction="#eliminarProducto"/>
        <TextField fx:id="txtBuscar" promptText="Buscar por código o nombre..." HBox.hgrow="ALWAYS"/>
        <Button text="Buscar" onAction="#buscarProducto"/>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS">
        <!-- TABLA PRODUCTOS -->
        <TableView fx:id="tablaProductos" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="130"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="150"/>
                <TableColumn fx:id="colPrecio" text="Precio ($)" prefWidth="80"/>
                <TableColumn fx:id="colStock" text="Stock" prefWidth="60"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="80"/>
                <TableColumn fx:id="colCategoria" text="Categoría ID" prefWidth="90"/>
            </columns>
        </TableView>

        <!-- FORMULARIO LATERAL -->
        <VBox fx:id="panelFormulario" prefWidth="300" spacing="10" visible="false" managed="false">
            <Label fx:id="lblTituloFormulario" text="Nuevo Producto" style="-fx-font-size:16; -fx-font-weight:bold;"/>
            <TextField fx:id="txtCodigo" promptText="Código del producto"/>
            <TextField fx:id="txtNombre" promptText="Nombre del Producto"/>
            <TextField fx:id="txtDescripcion" promptText="Descripción"/>
            <TextField fx:id="txtPrecio" promptText="Precio (Ej: 12.50)"/>
            <TextField fx:id="txtStock" promptText="Stock Inicial"/>
            <ComboBox fx:id="cmbEstado" promptText="Seleccionar Estado" maxWidth="Infinity"/>
            <ComboBox fx:id="cmbCategoria" promptText="Seleccionar Categoría" maxWidth="Infinity"/>
            <HBox spacing="10">
                <Button text="Guardar" onAction="#guardarProducto"/>
                <Button text="Cancelar" onAction="#cancelarFormulario"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>